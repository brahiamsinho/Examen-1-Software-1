# Spring Boot — ejemplo para desarrollo local
# Con Docker Compose, las variables suelen inyectarse desde el .env de la raíz.
# Usa este archivo si ejecutas el JAR o Maven en el host y los servicios
# Docker exponen puertos hacia localhost.

SERVER_PORT=8080
MONGODB_URI=mongodb://localhost:27017/tramitesdb
REDIS_HOST=localhost
REDIS_PORT=6379

