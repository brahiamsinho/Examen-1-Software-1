# Spring Boot — ejemplo para desarrollo local
# Con Docker Compose, las variables suelen inyectarse desde el .env de la raíz.
# Usa este archivo si ejecutas el JAR o Maven en el host y los servicios
# Docker exponen puertos hacia localhost.

SERVER_PORT=8080
MONGODB_URI=mongodb://localhost:27017/tramitesdb
REDIS_HOST=localhost
REDIS_PORT=6379

# Cliente HTTP hacia el microservicio FastAPI (red Docker: nombre del servicio)
FASTAPI_BASE_URL=http://localhost:8000

# JWT (mínimo 32 caracteres para HS256). Obligatorio en producción.
JWT_SECRET=cambia-esto-en-produccion-minimo-32-bytes!!
JWT_EXPIRATION_MINUTES=120

# Semilla de roles/usuarios demo (Mongo vacío). Desactivar en producción.
APP_DEV_AUTH_SEED_ENABLED=true

# Orígenes CORS separados por coma (Angular, Flutter web, etc.)
APP_CORS_ALLOWED_ORIGINS=http://localhost:4200
