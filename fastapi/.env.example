# FastAPI microservicio IA / analítica — copiar a .env para desarrollo local

APP_ENV=development
APP_NAME=tramites-ia-api
# Prefijo del router agrupado (sin versión en la URL)
API_PREFIX=/api
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# Orígenes CORS separados por coma, o * en desarrollo
CORS_ORIGINS=*

# Reservado para integraciones posteriores (no obligatorio en el esqueleto)
# MONGODB_URI=mongodb://localhost:27017/tramitesdb
# OPENAI_API_KEY=
