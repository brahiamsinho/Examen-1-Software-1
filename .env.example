# =============================================================
# Plataforma de Trámites — variables de entorno (EJEMPLO)
# Copia este archivo a la raíz como ".env" antes de docker compose.
# No subas ".env" al repositorio.
# =============================================================

# --- Entrada única (Nginx) ---
NGINX_PORT=80

# --- MongoDB (contenedor vacío; nombre lógico de BD inicial) ---
MONGO_DB=tramitesdb

# --- Spring Boot (puerto 8080 fijo dentro de Docker; Nginx hace proxy a backend:8080) ---
MONGODB_URI=mongodb://mongo:27017/tramitesdb
REDIS_HOST=redis
REDIS_PORT=6379
# URL base que Spring Boot usa para llamar a FastAPI (red Docker: nombre del servicio)
FASTAPI_BASE_URL=http://fastapi:8000

# --- Auth JWT (Spring Boot; mínimo 32 caracteres) ---
JWT_SECRET=cambia-esto-en-produccion-minimo-32-bytes!!
JWT_EXPIRATION_MINUTES=120
APP_DEV_AUTH_SEED_ENABLED=true
APP_CORS_ALLOWED_ORIGINS=http://localhost:4200

# --- FastAPI (puerto interno por defecto 8000; Nginx: /fastapi/ → raíz del servicio; health: GET /health) ---
APP_ENV=development
FASTAPI_APP_NAME=tramites-ia-api
FASTAPI_LOG_LEVEL=INFO
FASTAPI_CORS_ORIGINS=*
FASTAPI_PORT=8000
# Prefijo de rutas agrupadas del microservicio FastAPI (sin /v1)
FASTAPI_API_PREFIX=/api

# --- Ejemplos para más adelante (no activos en compose por defecto) ---
# Publicar FastAPI en el host (añade ports al servicio fastapi en compose si lo necesitas):
# FASTAPI_PORT=8000
# Redis con contraseña en producción:
# REDIS_PASSWORD=cambia_esto

# MongoDB con autenticación (requiere ajustar servicio mongo y esta URI):
# MONGODB_URI=mongodb://admin:tu_password@mongo:27017/tramitesdb?authSource=admin
