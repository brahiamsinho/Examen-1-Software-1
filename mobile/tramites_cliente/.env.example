# Backend API base URL (sin barra final). Spring en la raíz: /api/auth/login, etc.
#
# Docker Compose: el servicio `backend` publica 8080 al host (BACKEND_HOST_PORT, default 8080).
# Nginx (:80) no hace falta para la app móvil si usás este puerto directo.
#
# Android emulator (sin .env): http://10.0.2.2:8080
# Dispositivo físico (misma WiFi): http://IPv4_DE_TU_PC:8080  ← obligatorio crear .env
#
API_BASE_URL=http://192.168.0.10:8080
